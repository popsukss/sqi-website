generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum ResourceType {
  VIDEO
  PDF
  BOOK
  ARTICLE
}

enum ProgressStatus {
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

// ─── Auth (Better Auth required models) ──────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  sessions        Session[]
  accounts        Account[]
  forumPosts      ForumPost[]
  comments        ForumComment[]
  votes           Vote[]
  resources       Resource[]
  roadmapProgress UserRoadmapProgress[]
  checklistItems  UserChecklistItem[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

// ─── Homepage content ─────────────────────────────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  description String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Member {
  id       String  @id @default(cuid())
  name     String
  role     String
  bio      String?
  imageUrl String?
  order    Int     @default(0)
}

// ─── Forum ────────────────────────────────────────────────────────────────────

model ForumPost {
  id            String         @id @default(cuid())
  title         String
  body          String
  authorId      String
  author        User           @relation(fields: [authorId], references: [id])
  checkpointTag String?
  pinned        Boolean        @default(false)
  score         Int            @default(0)
  comments      ForumComment[]
  votes         Vote[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ForumComment {
  id        String    @id @default(cuid())
  body      String
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  score     Int       @default(0)
  votes     Vote[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Vote {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  value      Int
  postId     String?
  post       ForumPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId  String?
  comment    ForumComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  resourceId String?
  resource   Resource?     @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@unique([userId, resourceId])
}

// ─── Resources ────────────────────────────────────────────────────────────────

model Resource {
  id            String       @id @default(cuid())
  title         String
  url           String
  type          ResourceType
  description   String
  submittedById String
  submittedBy   User         @relation(fields: [submittedById], references: [id])
  approved      Boolean      @default(false)
  checkpointTag String?
  score         Int          @default(0)
  votes         Vote[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ─── Roadmap progress ─────────────────────────────────────────────────────────

model UserRoadmapProgress {
  userId    String
  nodeId    String
  status    ProgressStatus
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id])

  @@id([userId, nodeId])
}

model UserChecklistItem {
  userId  String
  nodeId  String
  itemKey String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, nodeId, itemKey])
}
